# Copy this file to .env and fill in values for local development and pre-push checks.
# Do NOT commit your real credentials or private keys. .env is gitignored.

# EC2 host (public IP or DNS)
EC2_HOST=

# SSH user for EC2 (e.g., ubuntu, ec2-user)
EC2_SSH_USER=ubuntu

# Path to your private key file (used locally for manual SSH). The CI expects the
# private key content in the GitHub secret `EC2_SSH_KEY` instead of a file path.
EC2_SSH_KEY_PATH=~/.ssh/deploy_ec2

# Optional: set protocol for EC2 smoke tests (http or https)
EC2_PROTOCOL=http
